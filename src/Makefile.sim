        putchars.o putchars_blink.o putchars_bold.o\
        putchars_rev.o contr_ring_bell.o getlog.o cursor_abs.o \
        cursor_off.o cursor_on.o help_ring_bell.o scroll_display.o\
        priv_bypass.o repaste_ast.o \
        ast.o syswake.o password_ok.o \
	fetch_tofile.o  dmp_dbuf.o dry_d_buf.o  \
	prepd.o run_dpolar.o run_d_buf.o  \
	put_help.o broadcast_dummy.o motdummy.o camacdummy.o

.SUFFIXES: $(.SUFFIXES) .src .for
# With readline 4.1 need to explicitly link against libcurses.so
LIBS = -lU77 -lcurses -lreadline -lm 
FC = f77

all: icp

icp: $(COBJ) $(FOBJ)
	$(FC) $(FOPTS) -o $@ $(FOBJ) $(COBJ) $(LIBS)
fsource:
	for a in *.src; do
	echo $a | $(PERL) -ne 's/\.src/\.f/; print' | xargs ${MAKE} ;\
	done
vmstar:
	for a in *.src; do \
	echo $$a | $(PERL) -ne 's/\.src/\.for/; print' ; \
	echo $$a | $(PERL) -ne 's/\.src/\.for/; print' | xargs ${MAKE} -s ;\
	done
	${TAR} cf icpvms.tar *.for
parport.o: parport.c
	$(CC) -O2 -Wall -c parport.c
.c.o:
	$(CC) $(COPTS) -c $*.c
.f.o:
	$(FC) $(FOPTS) -c $*.f
.src.f:
	$(CPP) $(CPPOPTS) $*.src |$(PERL) -ne 'print if /\S/' > $*.f
.src.for:
	$(CPP) $(CPPOPTS) -DVMS $*.src |$(PERL) -ne 'print if /\S/' > $*.for
clean:
	rm -f *.o *~ *.f *.for
realclean: clean
	rm -f icp 
